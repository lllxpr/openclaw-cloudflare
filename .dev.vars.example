# OpenClaw Gateway Token - used for Chat UI authentication
# Generate one with: openssl rand -hex 16
GATEWAY_AUTH_TOKEN=change-me

# Your Cloudflare Account ID
# Find it at: dash.cloudflare.com → any zone → Overview → right sidebar
AI_GATEWAY_ACCOUNT_ID=your-account-id

# Your AI Gateway name
# Create one at: dash.cloudflare.com → AI → AI Gateway
AI_GATEWAY_ID=your-gateway-id

# AI Gateway Auth Token - Cloudflare API token with AI Gateway permission
# Create at: dash.cloudflare.com → My Profile → API Tokens → Create Token
AI_GATEWAY_AUTH_TOKEN=your-api-token
